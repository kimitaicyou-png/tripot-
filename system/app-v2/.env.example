# tripot v2 環境変数

# DB
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# NextAuth v5
AUTH_SECRET=your-secret-here-min-32-chars
AUTH_GOOGLE_ID_V2=your-google-oauth-client-id
AUTH_GOOGLE_SECRET_V2=your-google-oauth-secret
NEXTAUTH_URL=https://coaris.ai/tripot

# 開発時のみ（@coaris.ai 以外のメアドを許可）
DEV_ALLOWED_EMAILS=k.toki@jtravel.group

# Microfrontends
NEXT_PUBLIC_BASE_PATH=/tripot
NEXT_PUBLIC_ASSET_PREFIX=/tripot

# Mem0（4姉妹常駐AI用）
MEM0_API_URL=https://mem0-coaris.fly.dev
MEM0_API_KEY=your-mem0-api-key

# Anthropic（aiAssistant feature）
ANTHROPIC_API_KEY=sk-ant-...

# Bridge（本部↔事業会社の内部 service token）
BRIDGE_SERVICE_TOKEN=your-internal-service-token

# MoneyForward Cloud（settings/mf）
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_API_KEY=

# Resend（メール送信）
RESEND_API_KEY=

# PostHog（観測）
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
