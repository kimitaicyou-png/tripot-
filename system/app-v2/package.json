{
  "name": "coaris-tripot-v2",
  "version": "0.1.0",
  "private": true,
  "description": "tripot v2 — コアリスHD 基準値プロジェクト（13社展開テンプレ元）",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start --port 3100",
    "lint": "next lint",
    "lint:ui": "bash scripts/coaris-ui-lint.sh",
    "type-check": "tsc --noEmit",
    "verify": "npm run type-check && npm run lint && npm run lint:ui && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@neondatabase/serverless": "^1.0.2",
    "ai": "^4.3.0",
    "drizzle-orm": "^0.44.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "sonner": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
